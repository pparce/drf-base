# Copy to .env (or set as real environment variables) for local development.
# ASP.NET Core maps double-underscore (__) to nested configuration sections.

ASPNETCORE_ENVIRONMENT=Development

# Database (PostgreSQL)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=aspbase;Username=postgres;Password=postgres

# JWT — MUST be a long random secret (>= 32 chars) in production
Jwt__SigningKey=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=asp-base
Jwt__Audience=asp-base

# Google Sign-In
Google__ClientId=

# Email (SMTP)
Email__Host=smtp.mailtrap.io
Email__Port=2525
Email__User=
Email__Password=
Email__UseTls=true
Email__FromEmail=noreply@example.com

# CORS (repeat with __0, __1 for multiple origins)
Cors__AllowedOrigins__0=http://localhost:3000
